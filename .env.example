# Example environment variables for local development
# Copy this file to .env and update with your values

# ---- Session (iron-session) ----
SESSION_PASSWORD=generate_a_strong_32_char_secret
SESSION_COOKIE_NAME=pckthscr_session

# ---- football-data.org API ----
API_KEY=your_football_data_api_key
API_URL=https://api.football-data.org/v4

# ---- PostgreSQL ----
# Local dev (matches docker-compose.yml: postgres on port 5435)
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/tip_manager?schema=public

# ---- Hetzner Object Storage (S3-compatible) ----
# Used for user avatars and pg_dump backups.
# See https://docs.hetzner.com/storage/object-storage/
HETZNER_OBJECT_STORAGE_ENDPOINT=https://fsn1.your-objectstorage.com
HETZNER_OBJECT_STORAGE_ACCESS_KEY=
HETZNER_OBJECT_STORAGE_SECRET_KEY=
HETZNER_OBJECT_STORAGE_BUCKET_AVATARS=pckthscr-avatars
HETZNER_OBJECT_STORAGE_BUCKET_BACKUPS=pckthscr-backups
HETZNER_OBJECT_STORAGE_REGION=fsn1

# ---- Backup encryption (age) ----
# Public key used by backup.sh to encrypt dumps before upload.
BACKUP_AGE_PUBLIC_KEY=

# ---- Local dev URL ----
NEXT_PUBLIC_API_URL=http://localhost:3000/api
