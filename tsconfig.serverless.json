{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "incremental": false,
    "outDir": ".build",
    "sourceMap": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src/lambdas/**/*"
  ],
  "exclude": [
    "node_modules",
    "src/tests",
    "src/app/**/*",
    ".next"
  ]
}