# Production .env for Hetzner VPS — place at /opt/pckthscr/.env
# Permissions: chmod 600. Do NOT commit a filled version.

# ── Postgres ──────────────────────────────────────────────────────────────
POSTGRES_USER=pckthscr
POSTGRES_PASSWORD=CHANGE_ME_strong_random_password
POSTGRES_DB=pckthscr

# ── App (iron-session + football-data API) ───────────────────────────────
SESSION_PASSWORD=CHANGE_ME_at_least_32_chars
SESSION_COOKIE_NAME=pckthscr_session
API_KEY=your_football_data_org_api_key

# ── Docker image ─────────────────────────────────────────────────────────
GITHUB_REPOSITORY=MRiazIsr/score-and-ods-game
IMAGE_TAG=latest

# ── Domain (Cloudflare orange-cloud → VPS:8080) ──────────────────────────
CADDY_DOMAIN=pickthescore.app
APP_HTTP_PORT=8080

# ── Backup (local disk, no S3 yet) ───────────────────────────────────────
# age public key; private key must live at /opt/pckthscr/.age-key (600 perms).
BACKUP_AGE_PUBLIC_KEY=age1...
BACKUP_LOCAL_DIR=/opt/pckthscr/backups
BACKUP_RETENTION=5
